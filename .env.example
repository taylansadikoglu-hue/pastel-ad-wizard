# Supabase (client)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# R-AD Engine
VITE_ENGINE_URL=https://api.revenuad.com

# Server-only — Similar Web Data (RapidAPI). Set before launch.
SIMILARWEB_RAPIDAPI_KEY=
SIMILARWEB_RAPIDAPI_HOST=similar-web-data.p.rapidapi.com

# Optional: Cloudflare / production deploy — bind the same vars in your worker secrets.

# Resend transactional email (revenuad.com)
# Use a "Sending access" API key in production (Resend → API Keys → Sending access).
# Domain management requires a separate full-access key in the Resend dashboard only.
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
APP_URL=https://revenuad.com
EMAIL_TEST_TO=
# Click-tracking links redirect through this subdomain (configured in Resend → Domains)
RESEND_TRACKING_SUBDOMAIN=rad.mail.revenuad.com
