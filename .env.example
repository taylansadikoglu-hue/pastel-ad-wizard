# Supabase (client)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# R-AD Engine
VITE_ENGINE_URL=https://api.revenuad.com

# Server-only — Similar Web Data (RapidAPI). Set before launch.
SIMILARWEB_RAPIDAPI_KEY=
SIMILARWEB_RAPIDAPI_HOST=similar-web-data.p.rapidapi.com

# Optional: Cloudflare / production deploy — bind the same vars in your worker secrets.

# Resend transactional email (revenuad.com)
# Use a "Sending access" API key in production (Resend → API Keys → Sending access).
# Domain management requires a separate full-access key in the Resend dashboard only.
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
APP_URL=https://revenuad.com
EMAIL_TEST_TO=
# Click-tracking links redirect through this subdomain (configured in Resend → Domains)
RESEND_TRACKING_SUBDOMAIN=rad.mail.revenuad.com

# Cloudflare R2 — creative vault (server)
# Token needs: Account → Cloudflare R2 → Edit (read/write objects)
CLOUDFLARE_API_TOKEN=
# Optional separate token for wrangler deploy / worker secrets
# Needs: Account → Workers Scripts → Edit
CLOUDFLARE_WORKERS_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=7169638abf93eba4c8a9644d870c35fa
R2_BUCKET_NAME=revenuead-creative-vault
R2_PUBLIC_URL=https://pub-cf328a68c22840b998bf5b84a553b21c.r2.dev
# S3-compatible reads (revenuead-worker-token — read-only on creative vault)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_S3_ENDPOINT=https://7169638abf93eba4c8a9644d870c35fa.r2.cloudflarestorage.com

# Cloudflare R2 — public base for client-side img src (no secrets)
VITE_R2_PUBLIC_URL=https://pub-cf328a68c22840b998bf5b84a553b21c.r2.dev
